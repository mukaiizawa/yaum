{
  "manifest_version": 3,
  "name": "yaum",
  "version": "1.0.0",
  "description": "Yet Another Userscript Manager for injecting custom scripts into pages on load.",
  "permissions": [
    "userScripts",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Reload yaum"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
